# Postgres connection for a role WITHOUT rls-bypass (see api/README.md).
# Local:    postgres://lightsoff_api:...@127.0.0.1:5432/lightsoff
# Supabase: use the pooler connection string with the dedicated api role.
DATABASE_URL=postgres://lightsoff_api:localdev@127.0.0.1:5432/lightsoff

# HS256 secret used to verify bearer tokens.
# On Supabase: Project Settings -> API -> JWT Secret (so Supabase Auth tokens work as-is).
JWT_SECRET=change-me-long-random-string

# Encryption key for the integration credential vault (never stored in the DB).
APP_ENCRYPTION_KEY=change-me-another-long-random-string

ALLOW_DEV_AUTH=true
