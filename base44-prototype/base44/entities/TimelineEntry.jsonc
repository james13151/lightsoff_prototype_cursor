{
  "name": "TimelineEntry",
  "type": "object",
  "properties": {
    "ticket_id": {
      "type": "string",
      "description": "\u5173\u8054\u5de5\u5355ID"
    },
    "author_id": {
      "type": "string",
      "description": "\u4f5c\u8005\u7528\u6237ID"
    },
    "author_name": {
      "type": "string",
      "description": "\u4f5c\u8005\u59d3\u540d"
    },
    "content": {
      "type": "string",
      "description": "\u5185\u5bb9"
    },
    "entry_type": {
      "type": "string",
      "enum": [
        "comment",
        "status_change",
        "assignment",
        "system",
        "channel_message",
        "ai_draft",
        "send_attempt"
      ],
      "default": "comment",
      "description": "\u6761\u76ee\u7c7b\u578b"
    },
    "is_system": {
      "type": "boolean",
      "default": false,
      "description": "\u662f\u5426\u4e3a\u4e0d\u53ef\u5220\u9664\u7684\u5ba1\u8ba1\u8bb0\u5f55"
    },
    "is_edited": {
      "type": "boolean",
      "default": false,
      "description": "\u662f\u5426\u5df2\u88ab\u7f16\u8f91"
    },
    "old_status": {
      "type": "string",
      "description": "\u72b6\u6001\u53d8\u66f4\u524d\u7684\u72b6\u6001"
    },
    "new_status": {
      "type": "string",
      "description": "\u72b6\u6001\u53d8\u66f4\u540e\u7684\u72b6\u6001"
    },
    "send_status": {
      "type": "string",
      "enum": [
        "sent",
        "failed",
        "blocked"
      ],
      "description": "Outbound send attempt result for omnichannel audit entries"
    },
    "provider": {
      "type": "string",
      "description": "Provider/channel name for omnichannel audit entries"
    }
  },
  "required": [
    "ticket_id",
    "content"
  ]
}
