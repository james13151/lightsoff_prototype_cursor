{
  "name": "Ticket",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "\u5de5\u5355\u6807\u9898"
    },
    "ticket_type": {
      "type": "string",
      "enum": [
        "\u6295\u8bc9",
        "\u9000\u8d27",
        "\u7269\u6d41\u5f02\u5e38",
        "\u54a8\u8be2"
      ],
      "description": "\u5de5\u5355\u7c7b\u578b"
    },
    "order_number": {
      "type": "string",
      "description": "\u8ba2\u5355\u53f7"
    },
    "tracking_number": {
      "type": "string",
      "description": "\u8ffd\u8e2a\u53f7"
    },
    "customer_name": {
      "type": "string",
      "description": "\u5ba2\u6237\u59d3\u540d"
    },
    "customer_contact": {
      "type": "string",
      "description": "\u8054\u7cfb\u65b9\u5f0f"
    },
    "platform": {
      "type": "string",
      "description": "\u6765\u6e90\u5e73\u53f0"
    },
    "channel_type": {
      "type": "string",
      "enum": [
        "email",
        "facebook",
        "instagram",
        "whatsapp"
      ],
      "description": "Omnichannel source"
    },
    "external_thread_id": {
      "type": "string",
      "description": "Provider conversation/thread id"
    },
    "external_customer_id": {
      "type": "string",
      "description": "Provider customer id"
    },
    "ai_intent": {
      "type": "string",
      "description": "AI-detected intent"
    },
    "ai_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "blocked"
      ],
      "description": "AI risk level"
    },
    "ai_summary": {
      "type": "string",
      "description": "AI conversation summary"
    },
    "send_policy_state": {
      "type": "string",
      "description": "Latest channel send policy state"
    },
    "last_external_message_at": {
      "type": "string",
      "format": "date-time",
      "description": "Latest external channel message timestamp"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u5f85\u5904\u7406",
        "\u5904\u7406\u4e2d",
        "\u5f85\u5ba2\u6237\u56de\u590d",
        "\u5df2\u89e3\u51b3",
        "\u5f85\u51fa\u5e93",
        "\u51fa\u5e93\u4e2d",
        "\u5f85\u53d1\u8d27",
        "\u5df2\u53d1\u8d27"
      ],
      "default": "\u5f85\u5904\u7406",
      "description": "\u5de5\u5355\u72b6\u6001"
    },
    "priority": {
      "type": "string",
      "enum": [
        "\u666e\u901a",
        "\u7d27\u6025"
      ],
      "default": "\u666e\u901a",
      "description": "\u4f18\u5148\u7ea7"
    },
    "due_date": {
      "type": "string",
      "format": "date-time",
      "description": "\u622a\u6b62\u65e5\u671f"
    },
    "assignee_id": {
      "type": "string",
      "description": "\u8d1f\u8d23\u4eba\u7528\u6237ID"
    },
    "assignee_name": {
      "type": "string",
      "description": "\u8d1f\u8d23\u4eba\u59d3\u540d"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u9644\u4ef6URL\u5217\u8868"
    },
    "read_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u5df2\u8bfb\u7528\u6237ID\u5217\u8868"
    },
    "linked_po_number": {
      "type": "string",
      "description": "\u5173\u8054\u91c7\u8d2d\u5355\u53f7"
    },
    "linked_outbound_id": {
      "type": "string",
      "description": "\u5173\u8054\u51fa\u5e93\u8bb0\u5f55ID"
    },
    "internal_notes": {
      "type": "string",
      "description": "\u5185\u90e8\u5907\u6ce8"
    },
    "internal_notes_updated_by": {
      "type": "string",
      "description": "\u5185\u90e8\u5907\u6ce8\u6700\u540e\u7f16\u8f91\u4eba"
    },
    "internal_notes_updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "\u5185\u90e8\u5907\u6ce8\u6700\u540e\u7f16\u8f91\u65f6\u95f4"
    },
    "is_archived": {
      "type": "boolean",
      "default": false,
      "description": "\u662f\u5426\u5df2\u5f52\u6863"
    },
    "archived_reason": {
      "type": "string",
      "enum": [
        "\u5df2\u89e3\u51b3",
        "\u5df2\u5220\u9664"
      ],
      "description": "\u5f52\u6863\u539f\u56e0"
    },
    "pre_archive_status": {
      "type": "string",
      "description": "\u5f52\u6863\u524d\u72b6\u6001\uff08\u7528\u4e8e\u6062\u590d\uff09"
    }
  },
  "required": [
    "title"
  ]
}
