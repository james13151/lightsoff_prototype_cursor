{
  "name": "Task",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "\u4efb\u52a1\u6807\u9898"
    },
    "parent_task_id": {
      "type": "string",
      "description": "\u7236\u4efb\u52a1ID\uff08\u53ef\u9009\uff0c\u7528\u4e8e\u5b50\u4efb\u52a1\u5c42\u7ea7\uff09"
    },
    "category": {
      "type": "string",
      "description": "\u5206\u7c7b\uff08\u6765\u81ea\u5206\u7c7b\u8868\uff09"
    },
    "module": {
      "type": "string",
      "description": "\u6a21\u5757\uff08\u6765\u81ea\u6a21\u5757\u8868\uff09"
    },
    "description": {
      "type": "string",
      "description": "\u8be6\u7ec6\u63cf\u8ff0\uff08\u5bcc\u6587\u672c\uff09"
    },
    "status": {
      "type": "string",
      "description": "\u72b6\u6001\uff08\u6765\u81ea\u72b6\u6001\u8868\uff09",
      "default": "\u5f85\u529e"
    },
    "priority": {
      "type": "string",
      "enum": [
        "\u666e\u901a",
        "\u91cd\u8981",
        "\u7d27\u6025",
        "\u5173\u952e"
      ],
      "default": "\u666e\u901a",
      "description": "\u4f18\u5148\u7ea7"
    },
    "assignee_id": {
      "type": "string",
      "description": "\u8d1f\u8d23\u4eba\u7528\u6237ID"
    },
    "assignee_name": {
      "type": "string",
      "description": "\u8d1f\u8d23\u4eba\u59d3\u540d\uff08\u5197\u4f59\uff09"
    },
    "responsible_type": {
      "type": "string",
      "enum": [
        "\u6211\u65b9",
        "\u5916\u534f"
      ],
      "default": "\u6211\u65b9",
      "description": "\u5de5\u4f5c\u7c7b\u578b"
    },
    "key_person": {
      "type": "string",
      "description": "\u5173\u952e\u8054\u7cfb\u4eba\uff08\u81ea\u7531\u6587\u672c\uff09"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "\u5f00\u59cb\u65e5\u671f"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "\u622a\u6b62\u65e5\u671f"
    },
    "current_situation": {
      "type": "string",
      "description": "\u5f53\u524d\u60c5\u51b5"
    },
    "next_step": {
      "type": "string",
      "description": "\u4e0b\u4e00\u6b65"
    },
    "notes": {
      "type": "string",
      "description": "\u5907\u6ce8"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u4f9d\u8d56\u4efb\u52a1ID\u5217\u8868\uff08\u6b64\u4efb\u52a1\u7b49\u5f85\u7684\u4efb\u52a1\uff09"
    },
    "linked_tickets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u5173\u8054\u5de5\u5355ID\u5217\u8868"
    },
    "linked_pos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u5173\u8054\u91c7\u8d2d\u5355ID\u5217\u8868"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u9644\u4ef6URL\u5217\u8868"
    },
    "is_archived": {
      "type": "boolean",
      "default": false,
      "description": "\u662f\u5426\u5df2\u5f52\u6863"
    },
    "created_by_id": {
      "type": "string",
      "description": "\u521b\u5efa\u4ebaID"
    },
    "created_by_name": {
      "type": "string",
      "description": "\u521b\u5efa\u4eba\u59d3\u540d"
    }
  },
  "required": [
    "title"
  ]
}