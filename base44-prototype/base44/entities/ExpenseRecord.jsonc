{
  "name": "ExpenseRecord",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "description": "\u65e5\u671f"
    },
    "category": {
      "type": "string",
      "enum": [
        "\u529e\u516c\u7528\u54c1",
        "\u8d27\u6b3e",
        "\u8fd0\u8d39",
        "\u5176\u4ed6"
      ],
      "description": "\u7c7b\u578b"
    },
    "amount": {
      "type": "number",
      "description": "\u91d1\u989d"
    },
    "note": {
      "type": "string",
      "description": "\u5907\u6ce8"
    },
    "attachment": {
      "type": "string",
      "description": "\u9644\u4ef6URL"
    },
    "submitted_by_id": {
      "type": "string",
      "description": "\u63d0\u4ea4\u4ebaID"
    },
    "submitted_by_name": {
      "type": "string",
      "description": "\u63d0\u4ea4\u4eba\u59d3\u540d"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u672a\u8fd8",
        "\u5df2\u8fd8"
      ],
      "default": "\u672a\u8fd8",
      "description": "\u72b6\u6001"
    },
    "settled_note": {
      "type": "string",
      "description": "\u7ed3\u7b97\u5907\u6ce8"
    }
  },
  "required": [
    "date",
    "category",
    "amount"
  ]
}